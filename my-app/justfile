# Phoenix Justfile — wraps phoenix CLI commands using bun
# Usage: just status, just regen, just regen-iu Items, etc.

# Default recipe shows help
help:
    @echo "Phoenix commands:"
    @echo "  just status          - Show trust dashboard"
    @echo "  just drift           - Check drift vs manifest"
    @echo "  just health          - Test LLM provider connectivity"
    @echo "  just regen           - Regenerate all IUs"
    @echo "  just regen-iu IU=    - Regenerate specific IU (e.g., just regen-iu Items)"
    @echo "  just stubs           - Regenerate with stubs (no LLM)"
    @echo "  just bootstrap       - Full pipeline: ingest → canonicalize → plan → generate"
    @echo "  just ingest          - Ingest spec changes"
    @echo "  just canonicalize    - Extract canonical requirements"
    @echo "  just plan            - Plan Implementation Units"
    @echo "  just diff            - Show clause-level diffs"
    @echo "  just inspect         - Open interactive pipeline visualizer"

# Phoenix binary path
phoenix := "bun /home/nandi/code/phoenix/dist/cli.js"

# Ensure phoenix is built from source (only if needed)
build-phoenix:
    @if [ ! -f /home/nandi/code/phoenix/dist/cli.js ] || [ -n "$(find /home/nandi/code/phoenix/src -type f -name '*.ts' -newer /home/nandi/code/phoenix/dist/cli.js 2>/dev/null | head -1)" ]; then \
        echo "Building phoenix..."; \
        cd /home/nandi/code/phoenix && npm run build 2>&1 | grep -E "(Bundled|error)" || echo "Build complete"; \
        echo ""; \
    fi

# Show trust dashboard
status: build-phoenix
    {{phoenix}} status

# Check drift vs manifest
drift: build-phoenix
    {{phoenix}} drift

# Test LLM provider connectivity
health:
    bun scripts/health.ts

# Regenerate all IUs
regen: build-phoenix
    {{phoenix}} regen

# Regenerate specific IU (usage: just regen-iu Items)
regen-iu IU: build-phoenix
    {{phoenix}} regen --iu={{IU}}

# Regenerate with stubs (no LLM)
stubs: build-phoenix
    {{phoenix}} regen --stubs

# Full pipeline: ingest → canonicalize → plan → generate
bootstrap: build-phoenix
    {{phoenix}} bootstrap

# Ingest spec changes
ingest: build-phoenix
    {{phoenix}} ingest

# Extract canonical requirements
canonicalize: build-phoenix
    {{phoenix}} canonicalize

# Plan Implementation Units
plan: build-phoenix
    {{phoenix}} plan

# Show clause-level diffs
diff: build-phoenix
    {{phoenix}} diff

# Open interactive pipeline visualizer
inspect: build-phoenix
    {{phoenix}} inspect

# Phoenix help
phoenix-help: build-phoenix
    {{phoenix}} help

# Run dev server (conventional, not phoenix-specific)
dev:
    bun run dev
