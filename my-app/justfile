# Phoenix Justfile — CLI handles prep (steps 1-3), PI skill handles the rest
# Usage: just prep → then tell PI: "run the phoenix-regen skill"

# Default recipe shows help
help:
    @echo "Phoenix Pipeline Commands:"
    @echo ""
    @echo "  just prep            - CLI: Ingest → Canonicalize → Plan (steps 1-3)"
    @echo ""
    @echo "After prep, use PI TUI:"
    @echo '  pi "run phoenix-regen skill"  - Regenerate (step 4)'
    @echo '  pi "validate and show status" - Validate (steps 5-7) + Dashboard (step 8)'
    @echo ""
    @echo "Provenance (optional):"
    @echo "  just provenance IU=  - Trace spec → code for IU"
    @echo ""
    @echo "Health check:"
    @echo "  just health          - Check server and tests"

# Phoenix source path (runs directly from source)
phoenix := "bun run /home/nandi/code/phoenix/src/cli.ts"

# === Phase 1: Prep (Steps 1-3 via CLI only) ===

# Step 1-3: Ingest → Canonicalize → Plan
prep:
    @echo "🔄 Phase 1: Prep (steps 1-3)"
    @echo ""
    @echo "Step 1/3: Ingesting spec..."
    {{phoenix}} ingest
    @echo ""
    @echo "Step 2/3: Canonicalizing requirements..."
    {{phoenix}} canonicalize
    @echo ""
    @echo "Step 3/3: Planning IUs..."
    {{phoenix}} plan
    @echo ""
    @echo "✅ Prep complete! IUs planned."
    @echo "   Now run PI: pi \"run phoenix-regen skill\""

# === Health Check ===

health:
    @echo "Checking server health..."
    @curl -s http://localhost:3000/health || echo "❌ Server not running"
    @echo ""
    @echo "Running tests..."
    bun test

# === Provenance (optional debugging) ===

# Trace spec → code for an IU
provenance IU:
    @echo "Provenance for {{IU}}:"
    @jq '.[] | select(.iu_id == "{{IU}}") | {name: .name, canon_ids: .source_canon_ids, files: [.outputs[].file]}' .phoenix/graphs/ius.json

# Show summary of all IUs and their files
provenance-summary:
    @echo "=== IU Summary ==="
    @jq -r '.[] | "\(.name) (\(.iu_id | .[0:8])): \(.outputs | length) files"' .phoenix/graphs/ius.json
