{
  "name": "phoenix-vcs",
  "version": "0.1.0",
  "description": "Regenerative version control system — causal compiler for intent",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "phoenix": "dist/phoenix"
  },
  "scripts": {
    "build": "bun build ./src/index.ts ./src/cli.ts --outdir=dist --target=bun",
    "build:types": "tsc --declaration --emitDeclarationOnly",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "phoenix": "bun dist/cli.js",
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.64.0",
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
