{
  "name": "phoenix-self",
  "version": "0.1.0",
  "description": "Generated by Phoenix VCS — 6 services (dog-food: Phoenix specs itself)",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start:ingestion": "tsc && node dist/generated/ingestion/server.js",
    "start:canonicalization": "tsc && node dist/generated/canonicalization/server.js",
    "start:implementation": "tsc && node dist/generated/implementation/server.js",
    "start:integrity": "tsc && node dist/generated/integrity/server.js",
    "start:operations": "tsc && node dist/generated/operations/server.js",
    "start:platform": "tsc && node dist/generated/platform/server.js",
    "start": "tsc && node dist/generated/platform/server.js"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "@types/node": "^22.0.0"
  }
}
